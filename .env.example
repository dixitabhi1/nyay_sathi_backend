APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173
AUTH_SECRET_KEY=replace-me-with-a-long-random-secret
AUTH_TOKEN_TTL_HOURS=24
ADMIN_EMAILS=
PERSISTENT_STORAGE_ROOT=

APP_SQLITE_PATH=storage/db/nyayasetu.sqlite3
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
ANALYTICS_DB_PATH=data/analytics/legal_corpus.duckdb

EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
VECTOR_INDEX_PATH=data/index/legal.index
VECTOR_METADATA_PATH=data/index/legal_metadata.json
LEGAL_CORPUS_PATH=data/corpus/official_legal_corpus.jsonl
BOOTSTRAP_CORPUS_PATH=data/sample/legal_corpus/legal_corpus.jsonl
OFFICIAL_SOURCES_MANIFEST_PATH=ingestion/configs/official_sources.json
JURISDICTION_GAZETTEER_PATH=data/sample/police_jurisdictions.json
TOP_K_RETRIEVAL=4

INFERENCE_PROVIDER=mock
INFERENCE_BASE_URL=http://inference:8000/v1
INFERENCE_MODEL_NAME=/models/mistral-7b-instruct
LOCAL_MODEL_NAME=microsoft/Phi-3-mini-4k-instruct
BNS_CLASSIFIER_MODEL_NAME=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
MAX_GENERATION_TOKENS=768
TEMPERATURE=0.2
INFERENCE_TIMEOUT_SECONDS=15

FIR_INFERENCE_PROVIDER=mock
FIR_INFERENCE_BASE_URL=http://inference:8000/v1
FIR_INFERENCE_MODEL_NAME=
FIR_LOCAL_MODEL_NAME=
FIR_MAX_GENERATION_TOKENS=900
FIR_TEMPERATURE=0.15
FIR_INFERENCE_TIMEOUT_SECONDS=10

UPLOAD_DIR=storage/uploads
OCR_LANGUAGE=eng+hin
WHISPER_MODEL=tiny
